{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://capital-cipher.ai/contracts/strategy.schema.json",
  "title": "Strategy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "strategy_id",
    "version",
    "enabled",
    "symbols",
    "timeframe",
    "minimum_confidence",
    "risk_profile",
    "required_agents",
    "optional_agents"
  ],
  "properties": {
    "strategy_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "enabled": { "type": "boolean" },
    "symbols": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "timeframe": { "type": "string" },
    "minimum_confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
    "risk_profile": { "type": "string", "enum": ["CONSERVATIVE", "MODERATE", "AGGRESSIVE"] },
    "required_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "optional_agents": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
